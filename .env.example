# Supabase — Project Settings → Data API (or API Keys in newer dashboards).
# URL: your project URL (https://xxxx.supabase.co).
# Client key: use the PUBLISHABLE key (sb_publishable_...) OR legacy "anon" JWT.
# Never put the SECRET / service_role key in Vite env — that bypasses RLS.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_OR_LEGACY_ANON_JWT
